# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose your AI suggestion engine:
#   groq   → Groq Cloud API (fast, requires API key)
#   ollama → Local Ollama model (private, no API key needed)
LLM_PROVIDER=ollama

# ── Groq Cloud (only needed when LLM_PROVIDER=groq) ──────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama Local (only needed when LLM_PROVIDER=ollama) ──────────────────────
# Install Ollama: https://ollama.com
# Pull the model: ollama pull meditron
# Start server:   ollama serve
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=meditron

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_DEBUG=true
PORT=5000
